{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "tms-backend",
      "source": "./tms-backend",
      "buildCommand": "./mvnw clean package -DskipTests",
      "startCommand": "java -Djava.net.preferIPv4Stack=true -jar target/tms-backend-1.0.0.jar",
      "rootDirectory": "tms-backend"
    },
    {
      "name": "tms-frontend",
      "source": "./tms-frontend",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm run preview",
      "rootDirectory": "tms-frontend"
    }
  ]
}
